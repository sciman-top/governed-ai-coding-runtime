{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/skill-manifest.schema.json",
  "title": "Skill Manifest",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "risk_tier": {
            "const": "high"
          }
        },
        "required": [
          "risk_tier"
        ]
      },
      "then": {
        "properties": {
          "default_enabled": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "input_modes": {
            "contains": {
              "enum": [
                "shell",
                "browser",
                "mcp"
              ]
            }
          }
        },
        "required": [
          "input_modes"
        ]
      },
      "then": {
        "required": [
          "tool_dependencies"
        ]
      }
    }
  ],
  "required": [
    "schema_version",
    "skill_id",
    "display_name",
    "version",
    "description",
    "entrypoint",
    "input_modes",
    "risk_tier",
    "capabilities",
    "provenance",
    "compatibility"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "skill_id": {
      "pattern": "^[a-z0-9_.-]+$",
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "input_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "prompt_only",
          "file_context",
          "structured_input",
          "mcp",
          "shell",
          "browser",
          "mixed"
        ],
        "type": "string"
      }
    },
    "risk_tier": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "version_or_digest"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "version_or_digest": {
          "type": "string"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_kernel_version"
      ],
      "properties": {
        "minimum_kernel_version": {
          "type": "string"
        },
        "required_contracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "default_enabled": {
      "type": "boolean"
    },
    "requires_approval": {
      "type": "boolean"
    },
    "repo_scopes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tool_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knowledge_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
