{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/core-principles.schema.json",
  "title": "Core Principles Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "status",
    "principles",
    "capability_portfolio_outcomes",
    "outer_ai_evolution_controls",
    "required_doc_refs",
    "forbidden_active_patterns",
    "evidence_refs",
    "rollback_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "policy_id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "observe",
        "enforced",
        "waived"
      ]
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "principle_id",
          "category",
          "summary",
          "required",
          "enforcement_level",
          "machine_gate",
          "rollback_ref"
        ],
        "properties": {
          "principle_id": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          },
          "category": {
            "type": "string",
            "enum": [
              "positioning",
              "host_boundary",
              "provider_boundary",
              "evolution",
              "verification",
              "evidence",
              "execution",
              "security"
            ]
          },
          "summary": {
            "type": "string"
          },
          "required": {
            "const": true
          },
          "enforcement_level": {
            "type": "string",
            "enum": [
              "docs_gate",
              "contract_gate",
              "runtime_gate"
            ]
          },
          "machine_gate": {
            "type": "string"
          },
          "rollback_ref": {
            "type": "string"
          }
        }
      }
    },
    "capability_portfolio_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "add",
          "keep",
          "improve",
          "merge",
          "deprecate",
          "retire",
          "delete_candidate"
        ]
      }
    },
    "outer_ai_evolution_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automatic_trigger_allowed",
        "allowed_automatic_actions",
        "forbidden_automatic_effective_actions",
        "required_controls"
      ],
      "properties": {
        "automatic_trigger_allowed": {
          "type": "boolean"
        },
        "allowed_automatic_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbidden_automatic_effective_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "required_controls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "required_doc_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "contains"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "contains": {
            "type": "string"
          }
        }
      }
    },
    "forbidden_active_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern",
          "scan_roots"
        ],
        "properties": {
          "pattern": {
            "type": "string"
          },
          "scan_roots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rollback_ref": {
      "type": "string"
    }
  }
}
