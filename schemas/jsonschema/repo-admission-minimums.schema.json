{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/repo-admission-minimums.schema.json",
  "title": "Repository Admission Minimums",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "required_inputs",
    "admission_checks",
    "failure_behavior",
    "non_goals"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "repository_identifier",
          "repo_profile_reference",
          "working_directory_or_checkout_locator",
          "control_pack_reference",
          "allowed_readonly_tools",
          "path_scope_policy",
          "verification_gate_commands_or_gate_na_records"
        ],
        "type": "string"
      }
    },
    "admission_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "blocking"
        ],
        "properties": {
          "id": {
            "pattern": "^check\\.[a-z0-9_.-]+$",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "failure_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_repo_profile",
        "invalid_control_pack",
        "missing_path_policy",
        "weakened_gate_semantics",
        "missing_optional_handoff_hints"
      ],
      "properties": {
        "missing_repo_profile": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "invalid_control_pack": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "missing_path_policy": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "weakened_gate_semantics": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "missing_optional_handoff_hints": {
          "enum": [
            "warn_only"
          ],
          "type": "string"
        }
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
