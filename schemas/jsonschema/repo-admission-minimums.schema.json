{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/repo-admission-minimums.schema.json",
  "title": "Repository Admission Minimums",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "required_inputs",
    "admission_checks",
    "compatibility_signals",
    "failure_behavior",
    "non_goals"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "repository_identifier",
          "repo_profile_reference",
          "working_directory_or_checkout_locator",
          "control_pack_reference",
          "allowed_readonly_tools",
          "path_scope_policy",
          "verification_gate_commands_or_gate_na_records",
          "knowledge_readiness_declaration_or_not_ready_signal",
          "eval_trace_policy_reference_or_not_ready_signal",
          "attachment_binding_or_attachment_posture_probe_result",
          "repo_override_summary"
        ],
        "type": "string"
      }
    },
    "admission_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "signal_kind",
          "default_status",
          "blocking"
        ],
        "properties": {
          "id": {
            "pattern": "^check\\.[a-z0-9_.-]+$",
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "signal_kind": {
            "enum": [
              "core_contract",
              "knowledge_readiness",
              "eval_readiness",
              "attachment_hygiene",
              "override_safety",
              "adapter_compatibility"
            ],
            "type": "string"
          },
          "default_status": {
            "enum": [
              "accept",
              "warn",
              "block"
            ],
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          }
        }
      }
    },
    "compatibility_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "signal_id",
          "signal_kind",
          "status",
          "reason",
          "blocking",
          "evidence_refs"
        ],
        "properties": {
          "signal_id": {
            "pattern": "^signal\\.[a-z0-9_.-]+$",
            "type": "string"
          },
          "signal_kind": {
            "enum": [
              "core_contract",
              "knowledge_readiness",
              "eval_readiness",
              "attachment_hygiene",
              "override_safety",
              "adapter_compatibility"
            ],
            "type": "string"
          },
          "status": {
            "enum": [
              "accept",
              "warn",
              "block"
            ],
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "failure_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_repo_profile",
        "invalid_control_pack",
        "missing_path_policy",
        "weakened_gate_semantics",
        "missing_knowledge_readiness_declaration",
        "missing_eval_readiness_declaration",
        "missing_or_stale_attachment_posture",
        "missing_optional_handoff_hints"
      ],
      "properties": {
        "missing_repo_profile": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "invalid_control_pack": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "missing_path_policy": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "weakened_gate_semantics": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "missing_knowledge_readiness_declaration": {
          "enum": [
            "warn_only"
          ],
          "type": "string"
        },
        "missing_eval_readiness_declaration": {
          "enum": [
            "warn_only"
          ],
          "type": "string"
        },
        "missing_or_stale_attachment_posture": {
          "enum": [
            "block_startup"
          ],
          "type": "string"
        },
        "missing_optional_handoff_hints": {
          "enum": [
            "warn_only"
          ],
          "type": "string"
        }
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
