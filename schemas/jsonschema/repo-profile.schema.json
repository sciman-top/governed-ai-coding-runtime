{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/repo-profile.schema.json",
  "title": "Repository Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repo_id",
    "display_name",
    "primary_language",
    "repo_root_locator",
    "rollout_posture",
    "build_commands",
    "test_commands",
    "lint_commands",
    "typecheck_commands",
    "risk_defaults",
    "approval_defaults",
    "tool_allowlist",
    "path_policies",
    "branch_policy",
    "delivery_format"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "repo_id": {
      "pattern": "^[a-zA-Z0-9_.-]+$",
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "primary_language": {
      "type": "string"
    },
    "repo_root_locator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "local_path",
            "workspace_anchor",
            "git_remote",
            "manual"
          ],
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "value"
      ]
    },
    "rollout_posture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_mode": {
          "type": "string",
          "enum": [
            "observe",
            "advisory",
            "enforced"
          ]
        },
        "target_mode": {
          "type": "string",
          "enum": [
            "observe",
            "advisory",
            "enforced"
          ]
        },
        "promotion_condition_ref": {
          "type": "string"
        }
      },
      "required": [
        "current_mode",
        "target_mode"
      ]
    },
    "build_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      }
    },
    "test_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      }
    },
    "lint_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "typecheck_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "contract_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "invariant_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "additional_gate_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "quick",
                "fast",
                "full",
                "l1",
                "l2",
                "l3",
                "all",
                "*"
              ]
            }
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "risk_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_write_tier": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "type": "string"
        },
        "blocked_command_patterns": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "approval_required_command_patterns": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "default_write_tier",
        "blocked_command_patterns"
      ]
    },
    "approval_defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "medium_write_requires_approval": {
          "type": "boolean"
        },
        "high_requires_explicit_approval": {
          "type": "boolean"
        }
      },
      "required": [
        "high_requires_explicit_approval"
      ]
    },
    "tool_allowlist": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "path_policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "read_allow": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "write_allow": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "blocked": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "read_allow",
        "write_allow",
        "blocked"
      ]
    },
    "branch_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_branch": {
          "type": "string"
        },
        "working_branch_prefix": {
          "type": "string"
        },
        "allow_direct_push": {
          "type": "boolean"
        }
      },
      "required": [
        "default_branch",
        "working_branch_prefix",
        "allow_direct_push"
      ]
    },
    "delivery_format": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary_template": {
          "type": "string"
        },
        "include_patch": {
          "type": "boolean"
        },
        "include_pr_body": {
          "type": "boolean"
        }
      },
      "required": [
        "summary_template"
      ]
    },
    "repo_map_strategy": {
      "enum": [
        "none",
        "symbol_graph",
        "repo_map",
        "hybrid"
      ],
      "type": "string"
    },
    "gate_timeout_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "quick_gate_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "full_gate_commands": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "blocking": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "satisfies_gate_ids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_applicable": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "command"
        ]
      },
      "type": "array"
    },
    "task_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "persistence_kind": {
          "type": "string",
          "enum": [
            "file_json"
          ]
        },
        "store_root": {
          "type": "string"
        },
        "supports_pause_resume": {
          "type": "boolean"
        },
        "supports_retry_timeout": {
          "type": "boolean"
        }
      },
      "required": [
        "persistence_kind",
        "store_root",
        "supports_pause_resume",
        "supports_retry_timeout"
      ]
    },
    "extra_eval_suites": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "context_files": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "reviewer_handoff_template": {
      "type": "string"
    },
    "compatibility_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "capability": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "full_support",
              "partial_support",
              "unsupported"
            ]
          },
          "degrade_to": {
            "type": "string",
            "enum": [
              "observe",
              "advisory",
              "enforced",
              "blocked",
              "fail_closed"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "capability",
          "status"
        ]
      }
    },
    "auto_commit_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "any_pass",
              "fast_pass",
              "full_pass",
              "milestone"
            ]
          }
        },
        "milestone_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "require_all_required_gates_pass": {
          "type": "boolean"
        },
        "commit_message_template": {
          "type": "string"
        }
      },
      "required": [
        "enabled"
      ]
    },
    "required_entrypoint_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_mode": {
          "type": "string",
          "enum": [
            "advisory",
            "targeted_enforced",
            "repo_wide_enforced"
          ]
        },
        "target_mode": {
          "type": "string",
          "enum": [
            "advisory",
            "targeted_enforced",
            "repo_wide_enforced"
          ]
        },
        "canonical_entrypoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow_direct_entrypoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "targeted_enforcement_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "promotion_condition_ref": {
          "type": "string"
        }
      },
      "required": [
        "current_mode",
        "target_mode",
        "canonical_entrypoints",
        "allow_direct_entrypoints",
        "targeted_enforcement_scopes"
      ]
    },
    "interaction_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_mode": {
          "type": "string",
          "enum": [
            "terse",
            "guided",
            "teaching"
          ]
        },
        "term_explain_style": {
          "type": "string",
          "enum": [
            "definition_only",
            "definition_plus_task_role",
            "definition_plus_common_mistake"
          ]
        },
        "default_checklist_kind": {
          "type": "string"
        },
        "compaction_preference": {
          "type": "string",
          "enum": [
            "stage_summary",
            "aggressive_compaction",
            "ref_only"
          ]
        },
        "summary_template": {
          "type": "string"
        },
        "handoff_teaching_notes": {
          "type": "string"
        }
      }
    }
  }
}

