{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/workflow-effect-metrics.schema.json",
  "title": "Workflow Effect Metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metrics_id",
    "workflow_mode_selected",
    "workflow_mode_source",
    "recommendation_improved",
    "mode_level_comparison_reason"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "metrics_id": { "type": "string" },
    "workflow_mode_selected": { "type": "string" },
    "workflow_mode_source": { "type": "string" },
    "recommendation_improved": { "type": "boolean" },
    "mode_level_comparison_reason": { "type": "string" },
    "workflow_degrade_reason": { "type": "string" },
    "required_artifact_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
    "manual_intervention_count": { "type": "integer", "minimum": 0 },
    "time_saved_seconds": { "type": "integer", "minimum": 0 },
    "problem_run_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "deny_to_success_retries": { "type": "integer", "minimum": 0 },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
