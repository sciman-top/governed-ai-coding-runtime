{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/core-principle-change-proposal.schema.json",
  "title": "Core Principle Change Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_on",
    "change_id",
    "change_action",
    "principle_id",
    "category",
    "summary",
    "rationale",
    "source_refs",
    "target_active_files",
    "required_controls",
    "guard",
    "rollback"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_on": {
      "type": "string",
      "format": "date"
    },
    "change_id": {
      "type": "string",
      "pattern": "^principle\\.[a-z0-9_.-]+$"
    },
    "change_action": {
      "type": "string",
      "enum": [
        "add",
        "update",
        "deprecate",
        "retire",
        "delete_candidate"
      ]
    },
    "principle_id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "category": {
      "type": "string",
      "enum": [
        "positioning",
        "automation",
        "safety",
        "governance",
        "compatibility",
        "lifecycle"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_active_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "structured_candidate",
          "risk_gate",
          "machine_gate",
          "evidence_ref",
          "rollback_ref",
          "human_review_for_high_risk"
        ]
      }
    },
    "guard": {
      "$ref": "#/$defs/core_principle_change_guard"
    },
    "rollback": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "core_principle_change_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_policy_auto_apply",
        "active_spec_auto_apply",
        "verifier_auto_update",
        "skill_auto_enable",
        "target_repo_sync",
        "push",
        "merge",
        "requires_human_review_before_effective_change"
      ],
      "properties": {
        "active_policy_auto_apply": {
          "const": false
        },
        "active_spec_auto_apply": {
          "const": false
        },
        "verifier_auto_update": {
          "const": false
        },
        "skill_auto_enable": {
          "const": false
        },
        "target_repo_sync": {
          "const": false
        },
        "push": {
          "const": false
        },
        "merge": {
          "const": false
        },
        "requires_human_review_before_effective_change": {
          "const": true
        }
      }
    }
  }
}
