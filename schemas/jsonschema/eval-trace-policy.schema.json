{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/eval-trace-policy.schema.json",
  "title": "Eval And Trace Grading Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "required_eval_suites",
    "required_trace_fields",
    "trace_grading",
    "postmortem_inputs",
    "improvement_signal_flow"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "required_eval_suites": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "smoke",
          "regression",
          "adversarial",
          "cost"
        ],
        "type": "string"
      }
    },
    "required_trace_fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "trace_grading": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "required_dimensions",
        "minimum_dimension_coverage_rate",
        "failure_classifications"
      ],
      "properties": {
        "phase": {
          "enum": [
            "phase1_emit_only",
            "phase2_postmortem_ready",
            "phase3_improvement_ready"
          ],
          "type": "string"
        },
        "required_dimensions": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "evidence_completeness",
              "workflow_correctness",
              "replay_readiness",
              "outcome_quality"
            ],
            "type": "string"
          }
        },
        "minimum_dimension_coverage_rate": {
          "minimum": 0,
          "type": "number",
          "maximum": 1
        },
        "replay_readiness_required": {
          "type": "boolean"
        },
        "failure_classifications": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": [
              "missing_evidence",
              "policy_miss",
              "replay_gap",
              "poor_outcome_quality",
              "reviewer_disagreement",
              "repeated_failure_signature",
              "misalignment_not_caught",
              "over_explained_under_budget_pressure",
              "under_explained_with_high_user_confusion",
              "repeated_question_without_signal_upgrade",
              "observation_gap_ignored",
              "compression_without_recoverable_summary"
            ],
            "type": "string"
          }
        }
      }
    },
    "postmortem_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_sources",
        "required_fields",
        "required_dimension_links",
        "minimum_evidence_refs"
      ],
      "properties": {
        "required_sources": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "failed_run",
              "review_feedback",
              "repeated_failure_signature"
            ],
            "type": "string"
          }
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "input_id",
              "source_kind",
              "summary",
              "evidence_refs",
              "affected_dimensions",
              "failure_classifications",
              "follow_up_scope",
              "recorded_at"
            ],
            "type": "string"
          }
        },
        "required_dimension_links": {
          "type": "boolean"
        },
        "minimum_evidence_refs": {
          "minimum": 1,
          "type": "integer"
        },
        "interaction_ref_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "interaction_signal_refs",
              "interaction_policy_refs"
            ],
            "type": "string"
          }
        }
      }
    },
    "improvement_signal_flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_order",
        "proposal_generation_mode",
        "separates_repo_specific_followups"
      ],
      "properties": {
        "trigger_order": {
          "type": "array",
          "minItems": 4,
          "items": {
            "enum": [
              "evidence_persistence",
              "trace_grading",
              "postmortem_input_capture",
              "improvement_proposal_generation"
            ],
            "type": "string"
          }
        },
        "proposal_generation_mode": {
          "enum": [
            "human_review_required"
          ],
          "type": "string"
        },
        "separates_repo_specific_followups": {
          "type": "boolean"
        }
      }
    },
    "freshness_days": {
      "minimum": 1,
      "type": "integer"
    }
  }
}
