{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/policy-decision.schema.json",
  "title": "Policy Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "action_id",
    "risk_tier",
    "subject",
    "status",
    "decision_basis",
    "evidence_ref"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "allow"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "required_approval_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "escalate"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "required_approval_ref"
        ],
        "properties": {
          "required_approval_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "deny"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "remediation_hint"
        ],
        "properties": {
          "required_approval_ref": {
            "type": "null"
          },
          "remediation_hint": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "risk_tier": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "allow",
        "escalate",
        "deny"
      ]
    },
    "decision_basis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "required_approval_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "remediation_hint": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
