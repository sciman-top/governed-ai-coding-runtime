{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/workflow-governance.schema.json",
  "title": "Workflow Governance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workflow_governance_id",
    "default_workflow_mode",
    "allowed_workflow_modes",
    "workflow_mode_overrides_by_risk",
    "spec_artifact_requirements",
    "review_requirements",
    "worktree_policy",
    "subagent_policy",
    "automation_policy",
    "degrade_rules"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "workflow_governance_id": { "type": "string" },
    "default_workflow_mode": { "$ref": "#/$defs/workflow_mode" },
    "allowed_workflow_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/workflow_mode" }
    },
    "workflow_mode_overrides_by_risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "low": { "$ref": "#/$defs/workflow_mode" },
        "medium": { "$ref": "#/$defs/workflow_mode" },
        "high": { "$ref": "#/$defs/workflow_mode" }
      }
    },
    "spec_artifact_requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_for_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_mode" }
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "review_requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_for_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_mode" }
        },
        "reviewer_kind": { "type": "string" }
      }
    },
    "worktree_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_for_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_mode" }
        },
        "fallback_mode": { "$ref": "#/$defs/workflow_mode" }
      }
    },
    "subagent_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_for_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_mode" }
        },
        "fallback_mode": { "$ref": "#/$defs/workflow_mode" }
      }
    },
    "automation_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_for_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_mode" }
        },
        "fallback_mode": { "$ref": "#/$defs/workflow_mode" }
      }
    },
    "degrade_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requested_mode", "missing_capability", "fallback_mode"],
        "properties": {
          "requested_mode": { "$ref": "#/$defs/workflow_mode" },
          "missing_capability": { "type": "string" },
          "fallback_mode": { "$ref": "#/$defs/workflow_mode" }
        }
      }
    }
  },
  "$defs": {
    "workflow_mode": {
      "type": "string",
      "enum": [
        "direct_fix",
        "spec_first",
        "spec_plus_review",
        "worktree_isolated_execution",
        "parallel_subagent_assist",
        "maintenance_automation"
      ]
    }
  }
}
