{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/tool-contract.schema.json",
  "title": "Tool Contract Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tools"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "risk_class": {
                  "const": "high"
                }
              },
              "required": [
                "risk_class"
              ]
            },
            "then": {
              "not": {
                "properties": {
                  "approval_policy": {
                    "const": "auto_execute"
                  }
                },
                "required": [
                  "approval_policy"
                ]
              }
            }
          },
          {
            "if": {
              "properties": {
                "side_effect_class": {
                  "enum": [
                    "filesystem_write",
                    "network_write",
                    "external_state_change"
                  ]
                }
              },
              "required": [
                "side_effect_class"
              ]
            },
            "then": {
              "anyOf": [
                {
                  "required": [
                    "rollback_guidance"
                  ]
                },
                {
                  "required": [
                    "compensating_action_type"
                  ]
                }
              ]
            }
          }
        ],
        "properties": {
          "tool_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "risk_class": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "approval_policy": {
            "enum": [
              "auto_execute",
              "auto_if_reversible",
              "pre_publish_confirmation",
              "explicit_user_approval"
            ],
            "type": "string"
          },
          "side_effect_class": {
            "enum": [
              "none",
              "filesystem_read",
              "filesystem_write",
              "process_spawn",
              "network_read",
              "network_write",
              "external_state_change"
            ],
            "type": "string"
          },
          "timeout_ms": {
            "minimum": 1,
            "type": "integer"
          },
          "retry_policy": {
            "type": "string"
          },
          "idempotency_expectation": {
            "enum": [
              "required",
              "preferred",
              "best_effort",
              "not_applicable"
            ],
            "type": "string"
          },
          "sandbox_boundary": {
            "type": "string"
          },
          "trace_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "input_schema_ref": {
            "type": "string"
          },
          "output_schema_ref": {
            "type": "string"
          },
          "rollback_guidance": {
            "type": "string"
          },
          "compensating_action_type": {
            "type": "string"
          },
          "containment_profile": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tool_family",
              "workspace_root",
              "allowed_path_roots",
              "environment_policy",
              "network_posture",
              "timeout_ms",
              "approval_class",
              "evidence_refs",
              "rollback_refs"
            ],
            "properties": {
              "tool_family": {
                "enum": [
                  "file_write",
                  "shell",
                  "git",
                  "package_manager",
                  "browser_automation",
                  "mcp_tool_bridge"
                ],
                "type": "string"
              },
              "workspace_root": {
                "type": "string",
                "minLength": 1
              },
              "allowed_path_roots": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "environment_policy": {
                "enum": [
                  "minimal",
                  "sanitized_inherited",
                  "repo_profile_declared"
                ],
                "type": "string"
              },
              "network_posture": {
                "enum": [
                  "deny",
                  "read_only",
                  "declared_by_tool",
                  "allowlist_required"
                ],
                "type": "string"
              },
              "timeout_ms": {
                "minimum": 1,
                "type": "integer"
              },
              "approval_class": {
                "enum": [
                  "auto_execute",
                  "auto_if_reversible",
                  "explicit_user_approval",
                  "deny"
                ],
                "type": "string"
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "rollback_refs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "waiver_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "required": [
          "tool_name",
          "description",
          "risk_class",
          "approval_policy",
          "side_effect_class",
          "timeout_ms",
          "retry_policy",
          "idempotency_expectation",
          "sandbox_boundary",
          "trace_fields",
          "input_schema_ref",
          "output_schema_ref",
          "containment_profile"
        ]
      }
    }
  }
}

