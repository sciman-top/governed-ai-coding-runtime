{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/target-project-rule-coordination.schema.json",
  "title": "Target Project Rule Coordination",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "coordination_id",
    "rule_release",
    "project_contract_version",
    "workspace_root",
    "updated_on",
    "ci_contract",
    "targets"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "2.2"
    },
    "coordination_id": {
      "const": "target-project-rule-coordination"
    },
    "rule_release": {
      "type": "string",
      "minLength": 1
    },
    "project_contract_version": {
      "type": "string",
      "minLength": 1
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "updated_on": {
      "type": "string",
      "format": "date"
    },
    "ci_contract": {
      "$ref": "#/$defs/ci_contract"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/target"
      }
    }
  },
  "$defs": {
    "ci_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "version",
        "workflow_sha256"
      ],
      "properties": {
        "contract_id": {
          "const": "agent-rule-contract-ci"
        },
        "version": {
          "const": "2.1"
        },
        "workflow_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_max_bytes",
        "project_max_lines",
        "wrapper_max_lines",
        "effective_context_warning_lines"
      ],
      "properties": {
        "project_max_bytes": {
          "type": "integer",
          "minimum": 1024
        },
        "project_max_lines": {
          "type": "integer",
          "minimum": 20
        },
        "wrapper_max_lines": {
          "type": "integer",
          "minimum": 1
        },
        "effective_context_warning_lines": {
          "type": "integer",
          "minimum": 20
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_id",
        "repo_path",
        "github_repository",
        "github_visibility",
        "aggregate_mode",
        "ci_workflow_path",
        "tools",
        "project_common_rule",
        "claude_wrapper_rule",
        "claude_wrapper_mode",
        "project_contract_version",
        "reviewed_global_release",
        "required_anchors",
        "evidence_path",
        "budgets",
        "coordination_mode"
      ],
      "properties": {
        "repo_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "repo_path": {
          "type": "string",
          "minLength": 1
        },
        "github_repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "github_visibility": {
          "enum": [
            "public",
            "private"
          ]
        },
        "aggregate_mode": {
          "enum": [
            "checkout",
            "target_local_only"
          ]
        },
        "ci_workflow_path": {
          "const": ".github/workflows/agent-rule-contract.yml"
        },
        "tools": {
          "const": [
            "codex",
            "claude"
          ]
        },
        "project_common_rule": {
          "const": "AGENTS.md"
        },
        "claude_wrapper_rule": {
          "const": "CLAUDE.md"
        },
        "claude_wrapper_mode": {
          "enum": [
            "import_only",
            "local_delta"
          ]
        },
        "project_contract_version": {
          "type": "string",
          "minLength": 1
        },
        "reviewed_global_release": {
          "type": "string",
          "minLength": 1
        },
        "required_anchors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_path": {
          "type": "string",
          "minLength": 1
        },
        "budgets": {
          "$ref": "#/$defs/budgets"
        },
        "coordination_mode": {
          "const": "audit_only"
        }
      }
    }
  }
}
