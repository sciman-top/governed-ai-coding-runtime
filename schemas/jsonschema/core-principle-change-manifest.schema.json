{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/core-principle-change-manifest.schema.json",
  "title": "Core Principle Change Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_on",
    "source_command",
    "operation_paths",
    "guard",
    "rollback"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_on": {
      "type": "string",
      "format": "date"
    },
    "source_command": {
      "type": "string",
      "minLength": 1
    },
    "existing_file_behavior": {
      "type": "string",
      "enum": [
        "overwrite_same_candidate",
        "fail_if_exists"
      ]
    },
    "operation_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^docs/change-evidence/core-principle-change-(proposals|patches|reports)/[^/]+\\.json$"
      }
    },
    "operation_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "operation",
          "path",
          "risk",
          "sha256",
          "existing_file_behavior"
        ],
        "properties": {
          "operation": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^docs/change-evidence/core-principle-change-(proposals|patches|reports)/[^/]+\\.json$"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "existing_file_behavior": {
            "type": "string",
            "enum": [
              "overwrite_same_candidate",
              "fail_if_exists"
            ]
          }
        }
      }
    },
    "guard": {
      "$ref": "#/$defs/core_principle_change_guard"
    },
    "rollback": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "core_principle_change_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_policy_auto_apply",
        "active_spec_auto_apply",
        "verifier_auto_update",
        "skill_auto_enable",
        "target_repo_sync",
        "push",
        "merge",
        "requires_human_review_before_effective_change"
      ],
      "properties": {
        "active_policy_auto_apply": {
          "const": false
        },
        "active_spec_auto_apply": {
          "const": false
        },
        "verifier_auto_update": {
          "const": false
        },
        "skill_auto_enable": {
          "const": false
        },
        "target_repo_sync": {
          "const": false
        },
        "push": {
          "const": false
        },
        "merge": {
          "const": false
        },
        "requires_human_review_before_effective_change": {
          "const": true
        }
      }
    }
  }
}
