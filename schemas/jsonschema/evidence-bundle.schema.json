{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/evidence-bundle.schema.json",
  "title": "Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "repo_id",
    "goal",
    "non_goals",
    "acceptance_criteria",
    "assumptions",
    "commands_run",
    "tool_calls",
    "files_changed",
    "approvals",
    "required_evidence",
    "verification_results",
    "rollback_ref",
    "final_outcome",
    "open_questions",
    "created_at",
    "completed_at"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "repo_id": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "non_goals": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "acceptance_criteria": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "commands_run": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "command": {
            "type": "string"
          },
          "exit_code": {
            "type": "integer"
          },
          "started_at": {
            "format": "date-time",
            "type": "string"
          },
          "completed_at": {
            "format": "date-time",
            "type": "string"
          },
          "output_ref": {
            "type": "string"
          }
        }
      },
      "type": "array"
    },
    "tool_calls": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "tool_name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "trace_ref": {
            "type": "string"
          }
        }
      },
      "type": "array"
    },
    "files_changed": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "change_type": {
            "type": "string"
          }
        }
      },
      "type": "array"
    },
    "approvals": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "approval_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "approver": {
            "type": "string"
          },
          "decided_at": {
            "format": "date-time",
            "type": "string"
          }
        }
      },
      "type": "array"
    },
    "required_evidence": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "present",
              "missing_mandatory",
              "missing_allowed",
              "advisory_only"
            ]
          },
          "reason": {
            "type": "string"
          },
          "artifact_ref": {
            "type": "string"
          }
        },
        "required": [
          "kind",
          "status"
        ]
      },
      "type": "array"
    },
    "verification_results": {
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "gate_level": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "advisory",
              "skipped_not_applicable"
            ]
          },
          "artifact_ref": {
            "type": "string"
          }
        }
      },
      "type": "array"
    },
    "rollback_ref": {
      "type": "string"
    },
    "final_outcome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "blocked",
            "failed",
            "abandoned"
          ]
        },
        "summary": {
          "type": "string"
        },
        "risk_note": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "open_questions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "context_snapshot_ref": {
      "type": "string"
    },
    "repo_profile_ref": {
      "type": "string"
    },
    "prompt_registry_ref": {
      "type": "string"
    },
    "failure_signature": {
      "type": "string"
    },
    "replay_case_ref": {
      "type": "string"
    },
    "runtime_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trial_feedback": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trial_id": {
          "type": "string"
        },
        "repo_id": {
          "type": "string"
        },
        "adapter_tier": {
          "type": "string",
          "enum": [
            "native_attach",
            "process_bridge",
            "manual_handoff"
          ]
        },
        "follow_up_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "repo_specific",
              "onboarding_generic",
              "adapter_generic",
              "contract_generic"
            ]
          }
        }
      },
      "required": [
        "trial_id",
        "repo_id",
        "adapter_tier",
        "follow_up_categories"
      ]
    },
    "interaction_trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "signal_id": {
                "type": "string"
              },
              "signal_kind": {
                "type": "string"
              },
              "severity": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "signal_id",
              "signal_kind",
              "severity",
              "summary",
              "evidence_refs"
            ]
          }
        },
        "applied_policies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "policy_id": {
                "type": "string"
              },
              "mode": {
                "type": "string"
              },
              "posture": {
                "type": "string"
              },
              "clarification_mode": {
                "type": "string"
              },
              "compression_mode": {
                "type": "string"
              },
              "stop_or_escalate": {
                "type": "string"
              },
              "rationale_signal_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "policy_id",
              "mode",
              "posture",
              "clarification_mode",
              "compression_mode",
              "stop_or_escalate",
              "rationale_signal_ids"
            ]
          }
        },
        "task_restatements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "clarification_rounds": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "scenario": {
                "type": "string"
              },
              "questions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "answers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "scenario",
              "questions",
              "answers"
            ]
          }
        },
        "observation_checklists": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "checklist_kind": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "checklist_kind",
              "items"
            ]
          }
        },
        "terms_explained": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "term": {
                "type": "string"
              },
              "explanation_summary": {
                "type": "string"
              },
              "task_role": {
                "type": "string"
              }
            },
            "required": [
              "term",
              "explanation_summary",
              "task_role"
            ]
          }
        },
        "compression_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "compression_mode": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "retained_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "compression_mode",
              "summary",
              "retained_refs"
            ]
          }
        },
        "budget_snapshots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "budget_status": {
                "type": "string"
              },
              "used_explanation_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "used_clarification_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "used_compaction_tokens": {
                "type": "integer",
                "minimum": 0
              },
              "total_token_budget": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "budget_status",
              "used_explanation_tokens",
              "used_clarification_tokens",
              "used_compaction_tokens",
              "total_token_budget"
            ]
          }
        },
        "alignment_outcome": {
          "type": "string"
        },
        "stop_or_degrade_reason": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "completed_at": {
      "format": "date-time",
      "type": "string"
    }
  }
}

