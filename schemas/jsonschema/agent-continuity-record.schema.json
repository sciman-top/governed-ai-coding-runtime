{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/agent-continuity-record.schema.json",
  "title": "Agent Continuity Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "created_at",
    "updated_at",
    "tool_family",
    "surface",
    "repo_ref",
    "continuity_class",
    "account_alias",
    "provider_alias",
    "task_summary",
    "evidence_refs",
    "handoff_refs",
    "memory_refs",
    "sensitivity",
    "retention",
    "rollback_ref"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tool_family": {
      "type": "string",
      "enum": [
        "codex",
        "claude",
        "claude-desktop",
        "gemini",
        "other"
      ]
    },
    "surface": {
      "type": "string",
      "enum": [
        "codex-app",
        "codex-cli",
        "codex-exec",
        "claude-code-cli",
        "claude-desktop-code",
        "claude-desktop-chat",
        "operator",
        "mcp",
        "other"
      ]
    },
    "repo_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_id",
        "path"
      ],
      "properties": {
        "repo_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        }
      }
    },
    "continuity_class": {
      "type": "string",
      "enum": [
        "native_shared",
        "portable_shared",
        "referenced_only",
        "isolated_secret"
      ]
    },
    "account_alias": {
      "type": "string",
      "minLength": 1
    },
    "provider_alias": {
      "type": "string",
      "minLength": 1
    },
    "model_alias": {
      "type": "string"
    },
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "summary",
          "evidence_ref"
        ],
        "properties": {
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "default": []
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "handoff_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "memory_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "native_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/native_ref"
      },
      "default": []
    },
    "config_summary": {
      "type": "object",
      "description": "Non-secret read-only host posture details collected by an auditor.",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "array",
          "object",
          "null"
        ]
      },
      "default": {}
    },
    "sensitivity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "cross_account_injection",
        "contains_secret_material",
        "redaction_status"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "private",
            "secret_adjacent"
          ]
        },
        "cross_account_injection": {
          "type": "string",
          "enum": [
            "allowed",
            "blocked",
            "requires_explicit_request"
          ]
        },
        "contains_secret_material": {
          "type": "boolean"
        },
        "redaction_status": {
          "type": "string",
          "enum": [
            "not_needed",
            "redacted",
            "blocked"
          ]
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expires_at",
        "retirement_policy",
        "audit_history_preserved"
      ],
      "properties": {
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "retirement_policy": {
          "type": "string",
          "minLength": 1
        },
        "audit_history_preserved": {
          "type": "boolean"
        }
      }
    },
    "rollback_ref": {
      "type": "string",
      "minLength": 1
    },
    "platform_na": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies",
        "reason",
        "alternative_verification",
        "evidence_link",
        "expires_at"
      ],
      "properties": {
        "applies": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "alternative_verification": {
          "type": "string"
        },
        "evidence_link": {
          "type": "string"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "url",
            "runtime-artifact",
            "session-id",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "native_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "kind",
        "ref",
        "storage_policy"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "enum": [
            "codex",
            "claude",
            "claude-desktop",
            "operator",
            "other"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "sqlite",
            "jsonl",
            "config",
            "app-state",
            "transcript",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "storage_policy": {
          "type": "string",
          "enum": [
            "host_owned",
            "referenced_only",
            "portable_copy_allowed",
            "isolated_secret"
          ]
        }
      }
    }
  }
}
