{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-ai-coding-runtime.local/schemas/policy-tool-credential-audit.schema.json",
  "title": "Policy Tool Credential Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "status",
    "reviewed_on",
    "verification_command",
    "report_output_ref",
    "fail_closed_defaults",
    "entries",
    "target_repo_override_entries",
    "rollback_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "observe",
        "enforced"
      ]
    },
    "reviewed_on": {
      "type": "string",
      "format": "date"
    },
    "verification_command": {
      "type": "string",
      "minLength": 1
    },
    "report_output_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_ref": {
      "type": "string",
      "minLength": 1
    },
    "fail_closed_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unknown_tool",
        "overbroad_credential_scope",
        "missing_policy_basis",
        "unsupported_override"
      ],
      "properties": {
        "unknown_tool": {
          "type": "string",
          "enum": [
            "deny",
            "escalate"
          ]
        },
        "overbroad_credential_scope": {
          "type": "string",
          "enum": [
            "deny",
            "escalate"
          ]
        },
        "missing_policy_basis": {
          "type": "string",
          "enum": [
            "deny",
            "escalate"
          ]
        },
        "unsupported_override": {
          "type": "string",
          "enum": [
            "deny",
            "escalate"
          ]
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "tool_name",
          "host_surface",
          "registry_refs",
          "credential_scope",
          "policy_basis_refs",
          "evidence_refs",
          "decision",
          "remediation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "host_surface": {
            "type": "string",
            "minLength": 1
          },
          "registry_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "credential_scope": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "scope_id",
              "scope_kind",
              "resource_boundary",
              "owner_boundary",
              "allowed_actions"
            ],
            "properties": {
              "scope_id": {
                "type": "string",
                "minLength": 1
              },
              "scope_kind": {
                "type": "string",
                "enum": [
                  "none",
                  "user_owned_token",
                  "provider_env_reference",
                  "repo_local_file",
                  "mcp_server_registration",
                  "local_config_switch"
                ]
              },
              "resource_boundary": {
                "type": "string",
                "minLength": 1
              },
              "owner_boundary": {
                "type": "string",
                "minLength": 1
              },
              "allowed_actions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "policy_basis_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "decision": {
            "type": "string",
            "enum": [
              "allow",
              "escalate",
              "deny",
              "platform_na"
            ]
          },
          "remediation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "target_repo_override_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_id",
          "declared_rule",
          "limitation_note",
          "basis_refs"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "minLength": 1
          },
          "declared_rule": {
            "type": "string",
            "enum": [
              "tighten_only",
              "platform_limit_only"
            ]
          },
          "limitation_note": {
            "type": "string",
            "minLength": 1
          },
          "basis_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
