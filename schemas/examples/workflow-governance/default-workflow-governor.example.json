{
  "schema_version": "1.0",
  "workflow_governance_id": "default-workflow-governor",
  "default_workflow_mode": "direct_fix",
  "allowed_workflow_modes": [
    "direct_fix",
    "spec_first",
    "spec_plus_review",
    "worktree_isolated_execution",
    "parallel_subagent_assist",
    "maintenance_automation"
  ],
  "workflow_mode_overrides_by_risk": {
    "low": "direct_fix",
    "medium": "spec_first",
    "high": "spec_plus_review"
  },
  "spec_artifact_requirements": {
    "required_for_modes": [
      "spec_first",
      "spec_plus_review"
    ],
    "artifact_refs": [
      "docs/specs/workflow-governance-spec.md"
    ]
  },
  "review_requirements": {
    "required_for_modes": [
      "spec_plus_review"
    ],
    "reviewer_kind": "human_or_explicit_review_gate"
  },
  "worktree_policy": {
    "required_for_modes": [
      "worktree_isolated_execution"
    ],
    "fallback_mode": "spec_plus_review"
  },
  "subagent_policy": {
    "required_for_modes": [
      "parallel_subagent_assist"
    ],
    "fallback_mode": "spec_plus_review"
  },
  "automation_policy": {
    "required_for_modes": [
      "maintenance_automation"
    ],
    "fallback_mode": "direct_fix"
  },
  "degrade_rules": [
    {
      "requested_mode": "worktree_isolated_execution",
      "missing_capability": "supports_worktrees",
      "fallback_mode": "spec_plus_review"
    },
    {
      "requested_mode": "parallel_subagent_assist",
      "missing_capability": "supports_subagents",
      "fallback_mode": "spec_plus_review"
    },
    {
      "requested_mode": "maintenance_automation",
      "missing_capability": "supports_background_automation",
      "fallback_mode": "direct_fix"
    }
  ]
}
