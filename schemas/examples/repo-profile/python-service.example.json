{
  "schema_version": "1.0",
  "repo_id": "python-service-sample",
  "display_name": "Python Service Sample",
  "primary_language": "python",
  "repo_root_locator": {
    "kind": "workspace_anchor",
    "value": "python-service"
  },
  "rollout_posture": {
    "current_mode": "advisory",
    "target_mode": "enforced",
    "promotion_condition_ref": "docs/runbooks/control-rollback.md"
  },
  "build_commands": [
    {
      "id": "build-wheel",
      "command": "uv build",
      "required": true,
      "description": "Build the distributable package."
    }
  ],
  "test_commands": [
    {
      "id": "pytest-all",
      "command": "uv run pytest -q",
      "required": true,
      "description": "Run unit and integration tests."
    }
  ],
  "lint_commands": [
    {
      "id": "ruff-check",
      "command": "uv run ruff check .",
      "required": true,
      "description": "Static lint gate."
    }
  ],
  "typecheck_commands": [
    {
      "id": "pyright",
      "command": "uv run pyright",
      "required": true,
      "description": "Type-check the service."
    }
  ],
  "contract_commands": [
    {
      "id": "api-contracts",
      "command": "uv run pytest tests/contracts -q",
      "required": true,
      "description": "Run API contract regression checks."
    }
  ],
  "invariant_commands": [
    {
      "id": "migration-safety",
      "command": "uv run pytest tests/invariants -q",
      "required": false,
      "description": "Verify persistence invariants."
    }
  ],
  "risk_defaults": {
    "default_write_tier": "medium",
    "blocked_command_patterns": [
      "git reset --hard",
      "rm -rf",
      "dropdb"
    ],
    "approval_required_command_patterns": [
      "alembic upgrade head",
      "uv publish"
    ]
  },
  "approval_defaults": {
    "medium_write_requires_approval": true,
    "high_requires_explicit_approval": true
  },
  "tool_allowlist": [
    "shell",
    "apply_patch",
    "rg",
    "git",
    "python"
  ],
  "path_policies": {
    "read_allow": [
      "src/**",
      "tests/**",
      "docs/**",
      "pyproject.toml",
      "README.md"
    ],
    "write_allow": [
      "src/**",
      "tests/**",
      "docs/**",
      "pyproject.toml",
      "README.md"
    ],
    "blocked": [
      "infra/prod/**",
      "secrets/**",
      ".env*"
    ]
  },
  "branch_policy": {
    "default_branch": "main",
    "working_branch_prefix": "codex/",
    "allow_direct_push": false
  },
  "delivery_format": {
    "summary_template": "goal-plan-changes-verification-risks",
    "include_patch": false,
    "include_pr_body": true
  },
  "repo_map_strategy": "hybrid",
  "task_lifecycle": {
    "persistence_kind": "file_json",
    "store_root": ".runtime/tasks",
    "supports_pause_resume": true,
    "supports_retry_timeout": true
  },
  "quick_gate_commands": [
    {
      "id": "quick-lint",
      "command": "uv run ruff check src tests",
      "required": true,
      "description": "Fast lint gate."
    },
    {
      "id": "quick-test",
      "command": "uv run pytest tests/unit -q",
      "required": true,
      "description": "Fast unit smoke."
    }
  ],
  "full_gate_commands": [
    {
      "id": "build",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-runtime.ps1",
      "required": true,
      "description": "Canonical build gate."
    },
    {
      "id": "test",
      "command": "uv run pytest -q",
      "required": true,
      "description": "Canonical test gate."
    },
    {
      "id": "contract",
      "command": "uv run pytest tests/contracts -q",
      "required": true,
      "description": "Canonical contract gate."
    },
    {
      "id": "hotspot",
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/doctor-runtime.ps1",
      "required": true,
      "description": "Canonical doctor gate."
    }
  ],
  "extra_eval_suites": [
    "python-service-smoke",
    "api-regression"
  ],
  "context_files": [
    "README.md",
    "docs/architecture.md",
    "docs/runbooks/release.md"
  ],
  "interaction_profile": {
    "default_mode": "guided",
    "term_explain_style": "definition_plus_common_mistake",
    "default_checklist_kind": "bugfix",
    "compaction_preference": "stage_summary",
    "summary_template": "goal-plan-changes-verification-risks",
    "handoff_teaching_notes": "Keep bug triage focused on expected vs actual, request context, logs, and rollback notes."
  },
  "learning_assistance_policy": {
    "enabled": true,
    "observable_signals_only": true,
    "require_evidence_refs": true,
    "trigger_on_user_correction": true,
    "trigger_signals": [
      "intent_drift",
      "goal_scope_mismatch",
      "expected_actual_missing",
      "symptom_root_cause_confusion",
      "term_confusion",
      "repeated_question_no_progress",
      "repeated_failure",
      "observation_gap",
      "budget_pressure",
      "verbosity_overrun"
    ],
    "restatement_triggers": [
      "task_start",
      "before_write",
      "after_user_correction",
      "after_repeated_failure",
      "before_delivery"
    ],
    "bug_observation_checklist": [
      "expected",
      "actual",
      "repro_steps",
      "logs_or_screenshot"
    ],
    "max_terms_per_response": 1,
    "max_task_restatements_per_stage": 1,
    "max_observation_items": 4,
    "max_clarification_questions": 3,
    "teaching_style": "definition_task_role_common_mistake",
    "token_budget_policy": {
      "default_explanation_budget": 180,
      "default_clarification_budget": 120,
      "compression_mode": "stage_summary"
    },
    "degrade_to_handoff_on_budget_pressure": true
  },
  "compatibility_signals": [
    {
      "capability": "structured_events",
      "status": "full_support"
    }
  ],
  "reviewer_handoff_template": "Include API surface changes, migration notes, and rollback commands."
}
