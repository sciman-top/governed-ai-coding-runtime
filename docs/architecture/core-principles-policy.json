{
  "schema_version": "1.0",
  "policy_id": "default-core-principles",
  "status": "enforced",
  "principles": [
    {
      "principle_id": "efficiency_first",
      "category": "execution",
      "summary": "The long-lived operating principle is low interruption, continuous execution, bounded context, lower token and cost burn, necessary explanatory density, measured throughput, and safe automation.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "codex_claude_cooperation_hosts",
      "category": "host_boundary",
      "summary": "Codex and Claude Code are the user's primary AI coding hosts and must be integrated with before competing surfaces are considered.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "no_host_competition",
      "category": "positioning",
      "summary": "The project must not duplicate Codex or Claude Code chat UI, model loop, tool-calling surface, or host-owned memory UX.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "claude_third_party_provider_boundary",
      "category": "provider_boundary",
      "summary": "Claude Code support is local third-party Anthropic-compatible provider usage such as GLM or DeepSeek and must not require official Claude subscription entitlement.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "external_mechanism_selective_absorption",
      "category": "positioning",
      "summary": "Hermes Agent, OpenHands, SWE-agent, Letta, Mem0, LangGraph, Aider, Cline, OPA, MCP gateways, and similar projects are selective mechanism sources, not product identities.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "governance_hub_reusable_contract_final_state",
      "category": "positioning",
      "summary": "The best engineering final state is Governance Hub + Reusable Contract + Controlled Evolution loop + outer AI intelligent review/generation capability, implemented as governed controls rather than a competing host product.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "controlled_evolution_portfolio_lifecycle",
      "category": "evolution",
      "summary": "Self-evolution must classify existing and proposed capabilities as add, keep, improve, merge, deprecate, retire, or delete_candidate using evidence.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "automation_first_outer_ai_intelligent_evolution",
      "category": "evolution",
      "summary": "The runtime should automate deterministic governance work and may automatically trigger outer AI for intelligent review, knowledge extraction, candidate generation, and evolution proposals while effective changes remain gate-controlled.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "no_automatic_mutation_without_review",
      "category": "evolution",
      "summary": "Automatic policy mutation, skill enablement, target-repo sync, push, and merge remain disabled unless a later reviewed implementation explicitly changes the guard.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "evidence_and_rollback_required",
      "category": "evidence",
      "summary": "Planning, schema, script, rule, and governance baseline changes require fresh evidence, effect metrics, verification commands, explicit N/A expiry when applicable, and rollback records.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "context_budget_and_instruction_minimalism",
      "category": "execution",
      "summary": "Core rules, instruction files, repo maps, and memory artifacts must stay bounded, concise, and verifiable so context budget is preserved for the task, code, and evidence.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "least_privilege_tool_credential_boundary",
      "category": "security",
      "summary": "Tool permissions, sandbox scope, credentials, provider secrets, mounted paths, and network access must be least-privilege, auditable, and enforced through deterministic controls where possible.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "measured_effect_feedback_over_claims",
      "category": "evidence",
      "summary": "Capability completion claims must be backed by fresh target-run evidence, eval traces, effect feedback, verification commands, and rollback paths rather than documentation or code existence alone.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "hard_gate_order",
      "category": "verification",
      "summary": "Final delivery must preserve the build -> test -> contract/invariant -> hotspot gate order.",
      "required": true,
      "enforcement_level": "docs_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert core-principles policy change"
    },
    {
      "principle_id": "source_target_drift_integration_before_sync",
      "category": "verification",
      "summary": "Same-name source and deployed target files must be compared and either structurally integrated into the canonical source plus target copy, or blocked with evidence; direct blind overwrite is forbidden.",
      "required": true,
      "enforcement_level": "contract_gate",
      "machine_gate": "verify-core-principles",
      "rollback_ref": "git revert source-target drift integration policy change"
    }
  ],
  "capability_portfolio_outcomes": [
    "add",
    "keep",
    "improve",
    "merge",
    "deprecate",
    "retire",
    "delete_candidate"
  ],
  "outer_ai_evolution_controls": {
    "automatic_trigger_allowed": true,
    "allowed_automatic_actions": [
      "source_collection",
      "experience_extraction",
      "knowledge_candidate_generation",
      "skill_candidate_generation",
      "evolution_proposal_generation",
      "candidate_evaluation",
      "effect_feedback_analysis"
    ],
    "forbidden_automatic_effective_actions": [
      "active_policy_mutation",
      "skill_enablement",
      "target_repo_sync",
      "push",
      "merge",
      "reviewed_evidence_deletion",
      "active_gate_deletion"
    ],
    "required_controls": [
      "structured_candidate",
      "risk_gate",
      "machine_gate",
      "evidence_ref",
      "rollback_ref",
      "human_review_for_high_risk"
    ]
  },
