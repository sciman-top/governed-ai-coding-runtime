{
  "schema_version": "1.0",
  "baseline_id": "active-target-governance-baseline",
  "sync_revision": "2026-04-25.1",
  "required_profile_overrides": {
    "required_entrypoint_policy": {
      "current_mode": "targeted_enforced",
      "target_mode": "repo_wide_enforced",
      "canonical_entrypoints": [
        "runtime-flow",
        "runtime-flow-preset"
      ],
      "allow_direct_entrypoints": [
        "run-governed-task.status",
        "session-bridge.inspect_status",
        "session-bridge.inspect_evidence",
        "session-bridge.inspect_handoff",
        "verify-repo"
      ],
      "targeted_enforcement_scopes": [
        "run_quick_gate",
        "run_full_gate",
        "verify_attachment",
        "govern_attachment_write",
        "write_request",
        "write_execute",
        "execute_attachment_write"
      ],
      "promotion_condition_ref": "docs/governance/entrypoint-promotion.md"
    },
    "auto_commit_policy": {
      "enabled": true,
      "on": [
        "milestone"
      ],
      "milestone_markers": [
        "checkpoint",
        "milestone",
        "release-candidate"
      ],
      "require_all_required_gates_pass": true,
      "commit_message_template": "自动提交：{repo_id} 里程碑 {milestone} 门禁通过 {timestamp}"
    },
    "interaction_profile": {
      "default_mode": "guided",
      "term_explain_style": "definition_plus_task_role",
      "default_checklist_kind": "bugfix",
      "compaction_preference": "stage_summary",
      "summary_template": "goal-plan-changes-verification-risks",
      "handoff_teaching_notes": "Keep handoff notes short and focused on expected vs actual, repro steps, and remaining evidence gaps."
    },
    "windows_process_environment_policy": {
      "enabled": true,
      "scope": "windows_process_entrypoints",
      "required_variables": [
        "ComSpec",
        "SystemRoot",
        "WINDIR",
        "APPDATA",
        "LOCALAPPDATA",
        "PROGRAMDATA"
      ],
      "required_practice": "Normalize Windows process environment before running Python, Node, Codex, or child PowerShell from repo entrypoints.",
      "runtime_runbook": "docs/runbooks/windows-process-environment-recovery.md",
      "coding_guidance": [
        "When adding or editing a Windows PowerShell entrypoint that invokes Python, Node, Codex, or child PowerShell, initialize the Windows process environment before tool execution.",
        "If raw Python asyncio or Node CSPRNG probes fail only inside Codex or a wrapper process, treat it as process_environment_incomplete before blaming project code.",
        "Only run Winsock/IP reset after the same probes also fail in a fresh elevated PowerShell."
      ],
      "powershell_entrypoint_pattern": ". \"$PSScriptRoot\\Initialize-WindowsProcessEnvironment.ps1\"; Initialize-WindowsProcessEnvironment",
      "verification_commands": [
        "python -c \"import asyncio; print('asyncio ok')\"",
        "node -e \"console.log('node ok')\""
      ]
    }
  }
}
