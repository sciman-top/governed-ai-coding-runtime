{
  "schema_version": "1.0",
  "contract_id": "target-repo-rollout-contract",
  "sync_revision": "2026-05-02.1",
  "canonical_one_click_entrypoint": {
    "script": "scripts/runtime-flow-preset.ps1",
    "all_targets_apply_all_features_args": [
      "-AllTargets",
      "-ApplyAllFeatures"
    ],
    "coding_speed_profile_args": [
      "-AllTargets",
      "-ApplyCodingSpeedProfile"
    ],
    "feature_baseline_and_milestone_args": [
      "-AllTargets",
      "-ApplyFeatureBaselineAndMilestoneCommit",
      "-MilestoneTag",
      "milestone"
    ],
    "required_json_fields": [
      "apply_all_features",
      "apply_coding_speed_profile",
      "apply_feature_baseline_and_milestone_commit",
      "governance_baseline_sync_active",
      "governance_sync_managed_changed",
      "governance_sync_managed_blocked",
      "milestone_gate_mode",
      "milestone_gate_mode_source",
      "milestone_gate_mode_reason",
      "milestone_tag",
      "auto_commit_trigger"
    ]
  },
  "managed_file_rollout": {
    "distribution_scope": "repo_local_artifact",
    "required_managed_files": [
      {
        "path": ".governed-ai/verify-powershell-policy.py",
        "source": "docs/targets/templates/verify-powershell-policy.py",
        "management_mode": "block_on_drift"
      },
      {
        "path": ".claude/settings.json",
        "source": "docs/targets/templates/claude-code/settings.json",
        "management_mode": "json_merge"
      },
      {
        "path": ".claude/hooks/governed-pre-tool-use.py",
        "source": "docs/targets/templates/claude-code/governed-pre-tool-use.py",
        "management_mode": "block_on_drift"
      }
    ]
  },
  "repo_profile_ownership_contract": {
    "baseline_override_fields": [
      "required_entrypoint_policy",
      "auto_commit_policy",
      "interaction_profile",
      "learning_assistance_policy",
      "rule_file_coordination_policy",
      "windows_process_environment_policy"
    ],
    "derived_runtime_fields": [
      "quick_gate_commands",
      "full_gate_commands",
      "gate_timeout_seconds"
    ],
    "catalog_input_fields": [
      "repo_id",
      "display_name",
      "primary_language",
      "build_commands",
      "test_commands",
      "contract_commands"
    ]
  },
  "target_repo_speed_profile_rollout": {
    "distribution_scope": "runtime_orchestrated",
    "coding_speed_profile_args": [
      "-AllTargets",
      "-ApplyCodingSpeedProfile"
    ],
    "required_json_fields": [
      "apply_coding_speed_profile"
    ],
    "required_policy_fields": [
      "enabled",
      "materialize_quick_gate_commands",
      "materialize_full_gate_commands",
      "preserve_existing_gate_commands",
      "refresh_existing_derived_gate_commands",
      "default_gate_timeout_seconds",
      "quick_gate_timeout_seconds",
      "full_gate_timeout_seconds",
      "reason"
    ]
  },
  "milestone_auto_commit": {
    "baseline_field": "auto_commit_policy",
    "required_trigger": "milestone",
    "required_markers": [
      "checkpoint",
      "milestone",
      "release-candidate"
    ],
    "require_all_required_gates_pass": true,
    "message_language": "zh-CN",
    "required_message_tokens": [
      "自动提交",
      "里程碑",
      "{repo_id}",
      "{milestone}",
      "{timestamp}"
    ]
  },
  "runtime_orchestrated_capability_contracts": [
    {
      "capability_id": "target-repo-problem-trace-and-kpi",
      "required_json_fields": [
        "exported_target_repo_runs"
      ]
    },
    {
      "capability_id": "target-repo-runs-retention-prune",
      "required_json_fields": [
        "prune_target_repo_runs"
      ]
    },
    {
      "capability_id": "target-repo-gate-speed-controls",
      "required_json_fields": [
        "apply_coding_speed_profile",
        "milestone_gate_mode",
        "milestone_gate_mode_source",
        "milestone_gate_mode_reason"
      ]
    },
    {
      "capability_id": "source-string-contract-guard",
      "required_json_fields": [
        "governance_full_check_path",
        "governance_fast_check_path"
      ]
    },
    {
      "capability_id": "native-attach-runtime-flow",
      "required_json_fields": [
        "flow_mode"
      ],
      "required_script_tokens": [
        "native_attach",
        "AdapterPreference"
      ]
    }
  ],
  "target_repo_capabilities": [
    {
      "capability_id": "target-repo-entrypoint-enforcement",
      "distribution_scope": "profile_baseline",
      "reason": "目标仓必须知道并执行统一入口约束，否则会绕过 runtime-flow-preset。",
      "baseline_fields": [
        "required_entrypoint_policy"
      ]
    },
    {
      "capability_id": "milestone-auto-commit-zh-cn",
      "distribution_scope": "profile_baseline",
      "reason": "目标仓自动提交策略必须随 profile 下发，才能在目标仓 git 上生成中文里程碑提交。",
      "baseline_fields": [
        "auto_commit_policy"
      ]
    },
    {
      "capability_id": "low-token-guided-interaction-profile",
      "distribution_scope": "profile_baseline",
      "reason": "交互策略影响目标仓 AI 编码过程，应随目标仓 profile 统一同步。",
      "baseline_fields": [
        "interaction_profile"
      ]
    },
    {
      "capability_id": "low-token-learning-assistance-policy",
      "distribution_scope": "profile_baseline",
      "reason": "低 token 教学、误解识别、任务重述触发和 bug 观察清单会影响目标仓外层 AI 协作质量，应随目标仓 profile 统一同步。",
      "baseline_fields": [
        "learning_assistance_policy"
      ]
    },
    {
      "capability_id": "global-project-rule-coordination",
      "distribution_scope": "profile_baseline",
      "reason": "全局规则与项目级规则的 1+1>2 协同边界会直接影响 AI 编码执行质量，应随目标仓 profile 统一同步。",
      "baseline_fields": [
        "rule_file_coordination_policy"
      ]
    },
    {
      "capability_id": "windows-process-environment-policy",
      "distribution_scope": "profile_baseline",
      "reason": "Windows 子进程环境和 Codex/代理继承策略影响目标仓脚本与 Codex/gh 网络执行可靠性，应随目标仓 profile 统一同步。",
      "baseline_fields": [
        "windows_process_environment_policy"
      ]
    },
    {
      "capability_id": "target-repo-problem-trace-and-kpi",
      "distribution_scope": "runtime_orchestrated",
      "reason": "问题痕迹和 KPI 聚合写入本 runtime 的 docs/change-evidence/target-repo-runs，不应复制为目标仓 profile 字段。"
    },
    {
      "capability_id": "target-repo-runs-retention-prune",
      "distribution_scope": "runtime_orchestrated",
      "reason": "保留期清理由 runtime-flow-preset 执行，清理对象是 runtime evidence store，不是目标仓声明。"
    },
    {
      "capability_id": "target-repo-gate-speed-controls",
      "distribution_scope": "runtime_orchestrated",
      "reason": "fast/full、auto milestone gate 和 timeout 仍由一键运行入口编排；baseline 可从目标仓既有 build/test/contract 命令派生 quick/full gate command groups，但不下发固定跨仓命令覆盖。"
    },
    {
      "capability_id": "source-string-contract-guard",
      "distribution_scope": "runtime_orchestrated",
      "reason": "source-string contract guard 由 runtime-check 调用目标仓测试，不应把 runtime 检查器复制到目标仓。"
    },
    {
      "capability_id": "target-repo-dependency-baseline-enforcement",
      "distribution_scope": "repo_local_artifact",
      "reason": "依赖基线是目标仓本地受管文件和门禁事实，按目标仓已有 .governed-ai/dependency-baseline.json 管理，不属于 profile override 下发字段。"
    },
    {
      "capability_id": "native-attach-runtime-flow",
      "distribution_scope": "runtime_orchestrated",
      "reason": "native attach/live attach 是 runtime 连接姿态和运行流，不应把 runtime kernel 复制到目标仓。"
    }
  ],
  "target_profile_features": [
    {
      "feature_id": "target-repo-entrypoint-enforcement",
      "baseline_fields": [
        "required_entrypoint_policy"
      ],
      "rollout_modes": [
        "apply_all_features",
        "feature_baseline_only",
        "feature_baseline_and_milestone_commit"
      ],
      "milestone_commit_required": false
    },
    {
      "feature_id": "milestone-auto-commit-zh-cn",
      "baseline_fields": [
        "auto_commit_policy"
      ],
      "rollout_modes": [
        "apply_all_features",
        "feature_baseline_and_milestone_commit"
      ],
      "milestone_commit_required": true
    },
    {
      "feature_id": "low-token-guided-interaction-profile",
      "baseline_fields": [
        "interaction_profile"
      ],
      "rollout_modes": [
        "apply_all_features",
        "feature_baseline_only",
        "feature_baseline_and_milestone_commit"
      ],
      "milestone_commit_required": false
    },
    {
      "feature_id": "low-token-learning-assistance-policy",
      "baseline_fields": [
        "learning_assistance_policy"
      ],
      "rollout_modes": [
        "apply_all_features",
        "feature_baseline_only",
        "feature_baseline_and_milestone_commit"
      ],
      "milestone_commit_required": false
    },
    {
      "feature_id": "global-project-rule-coordination",
      "baseline_fields": [
        "rule_file_coordination_policy"
      ],
      "rollout_modes": [
        "apply_all_features",
        "feature_baseline_only",
        "feature_baseline_and_milestone_commit"
      ],
      "milestone_commit_required": false
    },
    {
      "feature_id": "windows-process-environment-policy",
      "baseline_fields": [
        "windows_process_environment_policy"
      ],
      "rollout_modes": [
        "apply_all_features",
        "feature_baseline_only",
        "feature_baseline_and_milestone_commit"
      ],
      "milestone_commit_required": false
    }
  ]
}
