{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://governed-agent-platform.local/schemas/tool-contract.schema.json",
  "title": "Tool Contract Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tools"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "risk_class": {
                  "const": "high"
                }
              },
              "required": [
                "risk_class"
              ]
            },
            "then": {
              "not": {
                "properties": {
                  "approval_policy": {
                    "const": "auto_execute"
                  }
                },
                "required": [
                  "approval_policy"
                ]
              }
            }
          },
          {
            "if": {
              "properties": {
                "side_effect_class": {
                  "enum": [
                    "filesystem_write",
                    "network_write",
                    "external_state_change"
                  ]
                }
              },
              "required": [
                "side_effect_class"
              ]
            },
            "then": {
              "anyOf": [
                {
                  "required": [
                    "rollback_guidance"
                  ]
                },
                {
                  "required": [
                    "compensating_action_type"
                  ]
                }
              ]
            }
          }
        ],
        "properties": {
          "tool_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "risk_class": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "approval_policy": {
            "enum": [
              "auto_execute",
              "auto_if_reversible",
              "pre_publish_confirmation",
              "explicit_user_approval"
            ],
            "type": "string"
          },
          "side_effect_class": {
            "enum": [
              "none",
              "filesystem_read",
              "filesystem_write",
              "process_spawn",
              "network_read",
              "network_write",
              "external_state_change"
            ],
            "type": "string"
          },
          "timeout_ms": {
            "minimum": 1,
            "type": "integer"
          },
          "retry_policy": {
            "type": "string"
          },
          "idempotency_expectation": {
            "enum": [
              "required",
              "preferred",
              "best_effort",
              "not_applicable"
            ],
            "type": "string"
          },
          "sandbox_boundary": {
            "type": "string"
          },
          "trace_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "input_schema_ref": {
            "type": "string"
          },
          "output_schema_ref": {
            "type": "string"
          },
          "rollback_guidance": {
            "type": "string"
          },
          "compensating_action_type": {
            "type": "string"
          }
        },
        "required": [
          "tool_name",
          "description",
          "risk_class",
          "approval_policy",
          "side_effect_class",
          "timeout_ms",
          "retry_policy",
          "idempotency_expectation",
          "sandbox_boundary",
          "trace_fields",
          "input_schema_ref",
          "output_schema_ref"
        ]
      }
    }
  }
}
