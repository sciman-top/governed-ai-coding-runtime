{
  "approval_defaults": {
    "high_requires_explicit_approval": true,
    "medium_write_requires_approval": true
  },
  "auto_commit_policy": {
    "enabled": true,
    "on": [
      "milestone"
    ],
    "milestone_markers": [
      "checkpoint",
      "milestone",
      "release-candidate"
    ],
    "require_all_required_gates_pass": true,
    "commit_message_template": "自动提交：{repo_id} 里程碑 {milestone} 门禁通过 {timestamp}"
  },
  "branch_policy": {
    "allow_direct_push": false,
    "default_branch": "main",
    "working_branch_prefix": "governed/"
  },
  "build_commands": [
    {
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-runtime.ps1",
      "id": "build",
      "required": true
    }
  ],
  "compatibility_signals": [
    {
      "capability": "native_attach",
      "degrade_to": "advisory",
      "reason": "native adapter capability has not been detected during attachment",
      "status": "unsupported"
    }
  ],
  "contract_commands": [
    {
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/verify-repo.ps1 -Check Contract",
      "id": "contract",
      "required": true
    }
  ],
  "delivery_format": {
    "include_patch": true,
    "include_pr_body": true,
    "summary_template": "default"
  },
  "display_name": "Governed AI Coding Runtime",
  "invariant_commands": [],
  "lint_commands": [],
  "path_policies": {
    "blocked": [
      ".git/**"
    ],
    "read_allow": [
      "**/*"
    ],
    "write_allow": [
      "src/**",
      "tests/**",
      "docs/**"
    ]
  },
  "primary_language": "python",
  "repo_id": "governed-ai-coding-runtime",
  "repo_root_locator": {
    "kind": "local_path",
    "value": "."
  },
  "required_entrypoint_policy": {
    "current_mode": "targeted_enforced",
    "target_mode": "repo_wide_enforced",
    "canonical_entrypoints": [
      "runtime-flow",
      "runtime-flow-preset"
    ],
    "allow_direct_entrypoints": [
      "run-governed-task.status",
      "session-bridge.inspect_status",
      "session-bridge.inspect_evidence",
      "session-bridge.inspect_handoff",
      "verify-repo"
    ],
    "targeted_enforcement_scopes": [
      "run_quick_gate",
      "run_full_gate",
      "verify_attachment",
      "govern_attachment_write",
      "write_request",
      "write_execute",
      "execute_attachment_write"
    ],
    "promotion_condition_ref": "docs/governance/entrypoint-promotion.md"
  },
  "risk_defaults": {
    "blocked_command_patterns": [],
    "default_write_tier": "medium"
  },
  "rollout_posture": {
    "current_mode": "observe",
    "target_mode": "advisory"
  },
  "schema_version": "1.0",
  "test_commands": [
    {
      "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/verify-repo.ps1 -Check Runtime",
      "id": "test",
      "required": true
    }
  ],
  "tool_allowlist": [
    "shell"
  ],
  "typecheck_commands": []
}
